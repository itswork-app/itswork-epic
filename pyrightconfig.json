{
  "venvPath": ".",
  "venv": "venv",
  "extraPaths": ["."],
  "executionEnvironments": [
    {
      "root": "."
    }
  ],
  "exclude": [
    "**/node_modules",
    "**/__pycache__",
    "venv"
  ],
  "ignore": [
    "**/*_pb2.py",
    "**/*_pb2_grpc.py"
  ],
  "reportMissingImports": true,
  "typeCheckingMode": "basic"
}
