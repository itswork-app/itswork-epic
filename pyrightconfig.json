{
  "venvPath": ".",
  "venv": "venv",
  "extraPaths": [
    ".",
    "./api",
    "./internal"
  ],
  "executionEnvironments": [
    {
      "root": ".",
      "pythonPath": "./venv/bin/python",
      "extraPaths": [
        ".",
        "./api",
        "./internal"
      ]
    }
  ],
  "exclude": [
    "**/node_modules",
    "**/__pycache__",
    "venv"
  ],
  "ignore": [
    "**/*_pb2.py",
    "**/*_pb2_grpc.py"
  ],
  "reportMissingImports": true,
  "typeCheckingMode": "basic"
}
